{
  "name": "panda-lavanda-start",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @panda-lavanda/web",
    "dev:web": "npm run dev --workspace @panda-lavanda/web",
    "dev:bot": "npm run dev --workspace @panda-lavanda/telegram-bot",
    "build": "npm run build --workspace @panda-lavanda/web",
    "build:web": "npm run build --workspace @panda-lavanda/web",
    "generate-routes": "npm run generate-routes --workspace @panda-lavanda/web",
    "test": "npm run test --workspace @panda-lavanda/web",
    "seed": "npm run seed --workspace @panda-lavanda/db",
    "seed:db": "npm run seed --workspace @panda-lavanda/db"
  }
}
