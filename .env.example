# ──────────────────────────────────────────────────────────────
# Panda Lavanda — пример переменных окружения.
#
# Скопируйте в ДВА файла (оба в .gitignore, не коммитятся):
#   cp .env.example .env             # корень репо — для drizzle-kit / seed
#   cp .env.example apps/web/.env    # веб-приложение — для npm run dev / build
#
# Зачем два: TanStack Start (через Vite loadEnv) грузит .env относительно
# config.root = apps/web/, а drizzle-kit и seed-скрипт — относительно корня
# репо. Каждый инструмент ищет .env в своей «домашней» папке.
# ──────────────────────────────────────────────────────────────

# Учётные данные PostgreSQL (контейнер `db`).
# Используются docker-compose.yml для инициализации БД.
POSTGRES_USER=panda
POSTGRES_PASSWORD=panda
POSTGRES_DB=panda

# Строка подключения для ЛОКАЛЬНЫХ команд на хосте
# (npm run dev, drizzle-kit generate/migrate/studio).
# Хост — localhost, т.к. веб-приложение работает вне Docker и стучится
# на проброшенный порт 5432.
#
# ВАЖНО: внутри docker-compose (сервис `migrate`) хост БД подменяется на `db` —
# это имя сервиса во внутренней сети. Вручную DATABASE_URL в .env указывается
# именно для хоста. См. docker-compose.yml → migrate.environment.
DATABASE_URL=postgresql://panda:panda@localhost:5432/panda
